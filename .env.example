# Database Configuration
DB_HOST=localhost
DB_NAME=elms_db
DB_USER=root
DB_PASS=

# Security Settings
DEFAULT_PASSWORD=TempPass123!
JWT_SECRET=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# Email Configuration (SMTP Settings)
# Priority: .env file settings override database settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=ELMS System
SMTP_ENCRYPTION=tls

# For Gmail: Enable 2FA and create App Password at https://myaccount.google.com/apppasswords
# For SendGrid: Use 'apikey' as SMTP_USER and API key as SMTP_PASS
# For Mailgun: Use your Mailgun SMTP credentials

# Application Settings
APP_ENV=production
DEBUG_MODE=false
SESSION_TIMEOUT=3600